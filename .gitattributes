# Normalize text files in the repository.
* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf

# Code, configuration, and documentation use LF for cross-platform consistency.
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.csv text eol=lf
